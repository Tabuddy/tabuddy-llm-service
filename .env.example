# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPEN_AI_KEY=your_azure_openai_key_here

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ── Environment ───────────────────────────────────────────────────────────────
# DEV = local development | PROD = download models from Azure on startup
ENV=DEV

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_CONNECTION=ATLAS

MONGO_USERNAME=your_mongo_username
MONGO_PASSWORD=your_mongo_password
MONGO_HOSTNAME=your_cluster.mongodb.net
MONGO_PORT=27017
MONGO_DB=your_database_name

# ── Meta-tag API override (optional) ─────────────────────────────────────────
# META_TAG_API_URL=https://meta-tag-api.tabuddy.co/parse-resume-hybrid

# ── LLM skill matcher cache ───────────────────────────────────────────────────
# Max number of (skill_a, skill_b) pairs cached in memory.
# Oldest 25% are evicted when the limit is reached.
LLM_SKILL_CACHE_MAX=10000

# ── skill_library_v2: LangGraph skill-library generation pipeline ────────────
# Web-search grounding — Brave is preferred; Firecrawl is used as a fallback
# when BRAVE_API_KEY is unset. Planner degrades gracefully if neither is set.
BRAVE_API_KEY=your_brave_search_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here

# Postgres DSN for the canonical skill library (db/schema.sql + db/schema_v2_additions.sql).
PG_DSN=postgresql://postgres:postgres@localhost:5432/tabuddy

# Production Postgres DSN — used by the /canonical-skill UI (canonical_skill_api.py).
# IMPORTANT: special chars in the password MUST be URL-encoded (e.g. ! → %21,
# @ → %40) or the URL parser will split on the wrong '@'. The catalog tables
# live in the 'dev' schema on prod, configured via CANONICAL_SKILL_DB_SCHEMA below.
PG_PROD=postgresql://linkedin_scraper:URL_ENCODED_PASSWORD@HOST:5432/postgres

# /canonical-skill UI overrides. Defaults: PG_PROD with schema='dev'.
# Set these only if you want to point the UI somewhere else (e.g. a staging
# DB) without touching the rest of the app's DATABASE_URL/SKILL_LIBRARY_SCHEMA.
# CANONICAL_SKILL_DB_URL=postgresql://...
# CANONICAL_SKILL_DB_SCHEMA=dev

# DATABASE_URL is read by SQLAlchemy 2.0 (db/session.py) and Alembic
# (alembic/env.py). When set, evals.run_csv_batch auto-loads each completed
# role into Postgres in-flight (--db-mode=auto). One-time setup:
#   uv run alembic upgrade head
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tabuddy

# Azure OpenAI embedding deployment used by db/embedding_backfill.py and
# db/normalization.py. Defaults to "text-embedding-3-small". Override only if
# your Azure deployment name differs.
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure OpenAI deployment name for the reasoning tier used by Planner/critics.
# Override only if your Azure deployment name differs from the model id "o4-mini".
REASONING_DEPLOYMENT=o4-mini

# Azure OpenAI deployment name for the generation tier used by the Skill Generator.
# Needs a model with current-world knowledge (late-2025+ cutoff) — o4-mini's
# early-2024 cutoff misses newer frameworks/tools. Override if your Azure
# deployment name differs from the model id "gpt-5.4".
GENERATION_DEPLOYMENT=gpt-5.4

# ── skill_library_v3: Stage 0 charter pipeline (admin UI at /generate-skills) ─
# Separate Postgres database from `tabuddy` so v3 work is isolated from
# the production canonical catalog. Apply the existing schema to it via
#   uv run python -m skill_library_v3.scripts.bootstrap_db
SKILL_LIBRARY_PG_DSN=postgresql://postgres:postgres@localhost:5432/skill-library

# Kaggle credentials for the JD ingest script. Either set these env vars OR
# drop ~/.kaggle/kaggle.json — kagglehub picks up either. Generate at
# https://www.kaggle.com/settings → "Create New Token".
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=linkedin_scraper
DB_PASSWORD=
DB_SSLMODE=disable
DB_SCHEMA=dev
SKILL_LIBRARY_SCHEMA=dev